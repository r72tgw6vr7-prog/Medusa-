# Medusa Tattoo München - Complete Environment Configuration
# Copy this file to .env.local and configure your actual values

# ==== BASIC SETUP ====
VITE_SITE_URL="https://www.muenchen-tattoo-studio.de"
VITE_BUSINESS_NAME="Medusa Tattoo München"
VITE_BUSINESS_PHONE="+49 (0) 89 269 313"
VITE_BUSINESS_EMAIL="info@medusa-tattoo.de"
VITE_BUSINESS_STREET="Altheimer Eck 11"
VITE_BUSINESS_POSTAL="80331"
VITE_BUSINESS_CITY="München"
VITE_BUSINESS_COUNTRY="DE"
VITE_WHATSAPP="+49 176 12345678"
VITE_OPENING_HOURS="Mo-Do 11:30-19:00, Fr-Sa 11:30-20:00, So geschlossen"

# ==== EMAIL SERVICE (Choose ONE) ====
# SendGrid (Recommended)
VITE_EMAIL_PROVIDER="sendgrid"
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"

# Alternative: Mailgun
# VITE_EMAIL_PROVIDER="mailgun"
# MAILGUN_API_KEY="your_mailgun_api_key_here"
# MAILGUN_DOMAIN="mg.medusa-tattoo-muenchen.de"

# Alternative: Amazon SES
# VITE_EMAIL_PROVIDER="amazonses"
# AWS_SES_ACCESS_KEY="your_aws_ses_access_key_here"
# AWS_SES_SECRET_KEY="your_aws_ses_secret_key_here"
# AWS_SES_REGION="eu-central-1"

# Alternative: SMTP
# VITE_EMAIL_PROVIDER="smtp"
# SMTP_HOST="smtp.your-provider.com"
# SMTP_PORT="587"
# SMTP_USER="your_smtp_username"
# SMTP_PASS="your_smtp_password"

# Email Configuration
VITE_FROM_EMAIL="info@medusa-tattoo-muenchen.de"
VITE_CONTACT_EMAIL="info@medusa-tattoo-muenchen.de"
VITE_BOOKING_EMAIL="bookings@medusa-tattoo-muenchen.de"
VITE_WEB3FORMS_KEY=""

# ==== PAYMENT PROVIDERS (German Standards) ====
# Stripe (Cards + SEPA)
VITE_STRIPE_PUBLISHABLE_KEY="STRIPE_PUBLISHABLE_KEY_EXAMPLE"
STRIPE_SECRET_KEY="STRIPE_SECRET_KEY_EXAMPLE"

# PayPal
PAYPAL_CLIENT_ID="your_paypal_client_id_here"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret_here"

# Klarna (Popular in Germany)
KLARNA_CLIENT_ID="your_klarna_client_id_here"
KLARNA_SECRET_KEY="your_klarna_secret_key_here"

# Sofortüberweisung
VITE_SOFORT_CONFIG_KEY="your_sofort_config_key_here"

# Giropay
VITE_GIROPAY_MERCHANT_ID="your_giropay_merchant_id_here"
VITE_GIROPAY_PROJECT_ID="your_giropay_project_id_here"

# ==== ZOHO CRM INTEGRATION ====
ZOHO_CLIENT_ID="your_zoho_client_id_here"
ZOHO_CLIENT_SECRET="your_zoho_client_secret_here"
ZOHO_REFRESH_TOKEN="your_zoho_refresh_token_here"
ZOHO_DOMAIN="eu"  # eu, com, in, com.au
ZOHO_SANDBOX="false"

# ==== GEOGRAPHIC COORDINATES ====
VITE_GEO_LAT="48.1374"
VITE_GEO_LNG="11.5755"

# ==== SEO & ANALYTICS ====
VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
VITE_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# ==== SECURITY ====
VITE_RECAPTCHA_SITE_KEY="your_recaptcha_site_key_here"
RECAPTCHA_SECRET_KEY="your_recaptcha_secret_key_here"

# ==== SOCIAL MEDIA ====
VITE_INSTAGRAM_URL="https://instagram.com/medusa_tattoo_munich"
VITE_FACEBOOK_URL="https://www.facebook.com/MedusaTattooPiercingMuenchen"

# ==== BUSINESS DETAILS ====
VITE_PRICE_RANGE="€€€"
VITE_CURRENCIES_ACCEPTED="EUR"
VITE_PAYMENT_METHODS="SEPA,Klarna,PayPal,Credit Card,Bank Transfer"

# ==== DEVELOPMENT ====
VITE_APP_ENV="development"
VITE_DEBUG="false"
VITE_ALLOWED_ORIGINS="https://www.muenchen-tattoo-studio.de,http://localhost:5173"

# ==== LEGACY (Remove in production) ====
VITE_EMAIL_SERVICE_ID="deprecated_use_direct_email_service"
VITE_EMAIL_TEMPLATE_ID="deprecated_use_direct_email_service" 
VITE_EMAIL_PUBLIC_KEY="deprecated_use_direct_email_service"
