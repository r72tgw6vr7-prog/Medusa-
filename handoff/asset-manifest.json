{
  "version": "1.0.0",
  "lastUpdated": "2025-11-11",
  "project": "Medusa Tattoo München",
  "assetCategories": {
    "logos": {
      "required": true,
      "formats": ["SVG", "PNG"],
      "variants": [
        {
          "name": "Primary Logo",
          "usage": "Main navigation, hero section",
          "formats": ["SVG (preferred)", "PNG @2x"],
          "colorVariants": ["White", "Magenta", "Full Color"],
          "minDimensions": "200x60px",
          "optimization": "SVG optimized with SVGO, PNG compressed"
        },
        {
          "name": "Logo Icon",
          "usage": "Favicon, mobile app icon, social media",
          "formats": ["SVG", "PNG", "ICO"],
          "sizes": ["16x16", "32x32", "180x180", "512x512"],
          "optimization": "Multiple sizes for different contexts"
        },
        {
          "name": "Logo Wordmark",
          "usage": "Footer, email signatures",
          "formats": ["SVG", "PNG @2x"],
          "colorVariants": ["White", "Magenta"]
        }
      ]
    },
    "photography": {
      "required": true,
      "categories": {
        "tattooWork": {
          "name": "Tattoo Portfolio",
          "minQuantity": 20,
          "recommended": 40,
          "specifications": {
            "format": "WebP with JPEG fallback",
            "quality": "85-90%",
            "dimensions": "1200x1600px (portrait) or 1600x1200px (landscape)",
            "aspectRatio": "3:4 or 4:3",
            "fileSize": "< 200KB (WebP), < 300KB (JPEG)",
            "colorSpace": "sRGB",
            "optimization": "Responsive srcset with 3 sizes: 400w, 800w, 1200w"
          },
          "requirements": [
            "Professional lighting",
            "Sharp focus on tattoo details",
            "Neutral or dark backgrounds",
            "Consistent color grading",
            "No watermarks or text overlays",
            "Model releases if faces visible"
          ],
          "metadata": {
            "required": ["artist", "style", "category"],
            "optional": ["date", "sessionDuration", "description"]
          }
        },
        "piercingWork": {
          "name": "Piercing Portfolio",
          "minQuantity": 10,
          "recommended": 20,
          "specifications": {
            "format": "WebP with JPEG fallback",
            "quality": "85-90%",
            "dimensions": "1200x1200px (square preferred)",
            "aspectRatio": "1:1 or 4:3",
            "fileSize": "< 150KB (WebP), < 250KB (JPEG)"
          }
        },
        "studioPhotos": {
          "name": "Studio Interior",
          "minQuantity": 8,
          "recommended": 12,
          "specifications": {
            "format": "WebP with JPEG fallback",
            "quality": "90%",
            "dimensions": "1920x1080px (landscape)",
            "aspectRatio": "16:9",
            "fileSize": "< 300KB (WebP), < 500KB (JPEG)"
          },
          "requirements": [
            "Wide-angle shots showing full space",
            "Detail shots of equipment/decor",
            "Clean, organized appearance",
            "Professional lighting",
            "No clients visible (privacy)"
          ]
        },
        "artistPortraits": {
          "name": "Artist Headshots",
          "minQuantity": 4,
          "specifications": {
            "format": "WebP with JPEG fallback",
            "quality": "90%",
            "dimensions": "800x800px (square)",
            "aspectRatio": "1:1",
            "fileSize": "< 150KB (WebP), < 250KB (JPEG)"
          },
          "requirements": [
            "Professional headshots",
            "Consistent lighting and background",
            "High-quality, sharp focus",
            "Neutral or brand-aligned backgrounds"
          ]
        }
      }
    },
    "icons": {
      "required": true,
      "library": "Lucide Icons (already integrated)",
      "customIcons": {
        "required": false,
        "format": "SVG",
        "specifications": {
          "viewBox": "0 0 24 24",
          "strokeWidth": "2",
          "fill": "none",
          "stroke": "currentColor"
        }
      }
    },
    "favicon": {
      "required": true,
      "files": [
        {
          "name": "favicon.ico",
          "size": "32x32, 16x16",
          "format": "ICO"
        },
        {
          "name": "favicon-16x16.png",
          "size": "16x16",
          "format": "PNG"
        },
        {
          "name": "favicon-32x32.png",
          "size": "32x32",
          "format": "PNG"
        },
        {
          "name": "apple-touch-icon.png",
          "size": "180x180",
          "format": "PNG"
        },
        {
          "name": "android-chrome-192x192.png",
          "size": "192x192",
          "format": "PNG"
        },
        {
          "name": "android-chrome-512x512.png",
          "size": "512x512",
          "format": "PNG"
        }
      ]
    },
    "socialMedia": {
      "required": true,
      "openGraphImages": {
        "default": {
          "dimensions": "1200x630px",
          "format": "PNG or JPEG",
          "fileSize": "< 300KB",
          "usage": "Facebook, LinkedIn, general sharing"
        },
        "twitter": {
          "dimensions": "1200x600px",
          "format": "PNG or JPEG",
          "fileSize": "< 300KB",
          "usage": "Twitter/X cards"
        }
      }
    }
  },
  "optimizationGuidelines": {
    "images": {
      "formats": {
        "primary": "WebP",
        "fallback": "JPEG",
        "vector": "SVG (for logos, icons)"
      },
      "compression": {
        "webp": "85-90% quality",
        "jpeg": "85% quality",
        "png": "Lossless compression with tools like TinyPNG"
      },
      "responsiveImages": {
        "srcset": "Provide 3 sizes: small (400w), medium (800w), large (1200w)",
        "sizes": "Use appropriate sizes attribute for responsive loading",
        "lazyLoading": "Implement native lazy loading for below-fold images"
      }
    },
    "tools": {
      "recommended": [
        "Squoosh (https://squoosh.app/) - Online image optimizer",
        "ImageOptim (Mac) - Batch image optimization",
        "TinyPNG - PNG/JPEG compression",
        "SVGO - SVG optimization",
        "Sharp (Node.js) - Automated image processing"
      ]
    }
  },
  "deliveryFormat": {
    "structure": {
      "logos": "/assets/logos/",
      "tattoos": "/assets/gallery/tattoos/",
      "piercings": "/assets/gallery/piercings/",
      "studio": "/assets/studio/",
      "artists": "/assets/team/",
      "favicon": "/public/"
    },
    "namingConvention": {
      "pattern": "category-descriptor-size.format",
      "examples": [
        "logo-primary-white.svg",
        "tattoo-blackwork-artist1-001.webp",
        "studio-interior-wide-01.webp",
        "artist-portrait-john-doe.webp"
      ],
      "rules": [
        "Use lowercase",
        "Use hyphens (not underscores or spaces)",
        "Include descriptive keywords",
        "Add sequential numbers for series"
      ]
    }
  },
  "accessibility": {
    "altText": {
      "required": true,
      "guidelines": [
        "Describe the content and context",
        "Keep under 125 characters",
        "Don't start with 'Image of' or 'Picture of'",
        "Include artist name for portfolio work",
        "Describe style and subject matter"
      ],
      "examples": {
        "tattoo": "Detailed blackwork sleeve tattoo featuring geometric patterns by Artist Name",
        "studio": "Modern tattoo studio interior with comfortable client chairs and professional equipment",
        "artist": "Professional headshot of Artist Name, tattoo artist specializing in realism"
      }
    }
  },
  "qualityChecklist": {
    "beforeDelivery": [
      "All images optimized to target file sizes",
      "WebP format with JPEG fallback provided",
      "Responsive image sets generated (3 sizes minimum)",
      "Alt text provided for all images",
      "File naming convention followed",
      "Color space set to sRGB",
      "EXIF data removed (privacy)",
      "Images tested on retina displays",
      "Loading performance verified (< 3s page load)"
    ]
  }
}
